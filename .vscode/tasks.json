{
 "version": "2.0.0",
 "tasks": [
  {
   "type": "cppbuild",
   "label": "build",
   "command": "g++",
   "args": [
    "-g",
    "${file}",
    "-o",
    "${fileDirname}/${fileBasenameNoExtension}.exe"
   ],
   "options": {
    "cwd": "${fileDirname}"
   },
   "problemMatcher": ["$gcc"],
   "group": {
    "kind": "build",
    "isDefault": true
   }
  }
 ]
}